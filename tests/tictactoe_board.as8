	jmp	:main
; tic spots
empty_spot:
data {
	0b00000000
	0b00000000
	0b00000000
	0b00000000
	0b00000000
	0b00000000
	0b00000000

	0b00000000		; padding
}
X_spot:
data {
	0b10000010
	0b01000100
	0b00101000
	0b00010000
	0b00101000
	0b01000100
	0b10000010

	0b00000000		; padding
}
O_spot:
data {
	0b00111000
	0b01000100
	0b10000010
	0b10000010
	0b10000010
	0b01000100
	0b00111000

	0b00000000		; padding
}

