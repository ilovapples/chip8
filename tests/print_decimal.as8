get_decimal_digit:
	mov	vd, #10
gdd_loop_start:
	key	ve
	movr	v0, ve
	subr	ve, vd
	skeq	vf, #1
	jmp	:gdd_loop_end
	jmp	:gdd_loop_start
gdd_loop_end:
	ret

read_print_decimal:
	movr	v2, v1
	movr	v1, v0

	jsl	:get_decimal_digit
	font	v0
	draw	v1, v2, #5

	jsl	:get_decimal_digit
	font	v0
	add	v1, #4
	draw	v1, v2, #5

	jsl	:get_decimal_digit
	font	v0
	add	v1, #4
	draw	v1, v2, #5

	ret

main:
	cls
	mvi	$1fd	; 3 bytes before program data
	mov	v0, #0
	mov	v1, #0
	jsl	:read_print_decimal

infinite_loop:
	jmp :infinite_loop
