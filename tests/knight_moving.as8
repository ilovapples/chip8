	jmp :main

draw_knight:
	mvi :knight_data
	draw v0, v1, #0xf

	add v1, #0xf
	mov v2, #0xf
	addi v2
	draw v0, v1, #0x5

	mov v2, #0x5
	addi v2
	add v0, #0x8
	add v1, #0xf1
	draw v0, v1, #0xf

	add v1, #0xf
	mov v2, #0xf
	addi v2
	draw v0, v1, #0x5

	ret

knight_data: data {
	0b00001110
	0b00010001
	0b00010111
	0b00010001
	0b00010001
	0b00110001
	0b01001110
	0b01001000
	0b11111100
	0b10000100
	0b10010100
	0b10111100
	0b10010100
	0b10010100
	0b01111011
	0b00110001
	0b00110001
	0b00110001
	0b00110001
	0b00111001

	0b00000000
	0b00000000
	0b00000000
	0b00000000
	0b00000000
	0b10000000
	0b01000000
	0b01000000
	0b01000001
	0b10100010
	0b10100100
	0b11011000
	0b10111000
	0b10010000
	0b10000000
	0b10000000
	0b10000000
	0b10000000
	0b10000000
	0b11000000
}

main:
	jsl :draw_knight

loop_start:
	key v2
	skne v2, #0
	jmp :loop_end

	skne v2, #7
	add v4, #0xff   ; subtract one by overflow

	skne v2, #9
	add v4, #1

	skne v2, #8
	add v5, #1

	skne v2, #5
	add v5, #0xff

	movr v0, v4
	movr v1, v5

	cls
	jsl :draw_knight

	jmp :loop_start

loop_end:
	ret
